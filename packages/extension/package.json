{
  "name": "@nebula/extension",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:nebula.openDashboard"
  ],
  "contributes": {
    "commands": [
      {
        "command": "nebula.openDashboard",
        "title": "Nebula: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Nebula",
      "properties": {
        "nebula.websocketUrl": {
          "type": "string",
          "default": "wss://127.0.0.1:7443/ws"
        },
        "nebula.tls.keyPath": {
          "type": "string",
          "default": ""
        },
        "nebula.tls.certPath": {
          "type": "string",
          "default": ""
        },
        "nebula.tls.caPath": {
          "type": "string",
          "default": ""
        }
      }
    }
  },
  "dependencies": {
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.10"
  }
}
